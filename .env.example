# ========== CONFIGURACIÓN REQUERIDA PARA NETLIFY ==========
# Copiar este archivo a .env y completar con tus credenciales
# NO SUBIR .env A GITHUB - Usar secrets de Netlify en lugar de esto

# ========== OPENAI (Para análisis IA) ==========
OPENAI_API_KEY=sk-your-api-key-here

# ========== SECOP II (Credenciales de acceso) ==========
SECOP_USER=901335221
SECOP_PASSWORD=tu-contraseña-aqui
SECOP_BASE_URL=https://www.secop.gov.co/CO1Marketplace/

# ========== EMAIL (Para notificaciones) ==========
EMAIL_SERVICE=gmail
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu-contraseña-app-aqui
EMAIL_FROM=noreply@connect-your-knowledge.com

# ========== GOOGLE DRIVE (Para sincronización documental) ==========
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8888/.netlify/functions/gdriveSyncer
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# ========== CONFIGURACIÓN DE LA APLICACIÓN ==========
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
MAX_RETRIES=3

# ========== URLs ==========
BASE_URL=https://regal-torte-5f94b1.netlify.app/
API_BASE_URL=https://regal-torte-5f94b1.netlify.app/api

# ========== LÍMITES Y CONFIGURACIÓN ==========
MAX_PROCESOS_POR_BUSQUEDA=100
TIMEOUT_BUSQUEDA_SEGUNDOS=60
FRECUENCIA_MONITOREO_HORAS=4

# ========== CONFIGURACIÓN DE SEGURIDAD ==========
